#!/bin/sh
set -eu

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"
[ -z "$staged_files" ] && exit 0

blocked_path_regex='(^|/)(dados_reais|dados-sensiveis|dados_sensiveis|sensiveis|sigilosos|exports|backup|backups)/'
blocked_ext_regex='\.(xlsx|xls|parquet|db|sqlite|bak)$'
allowed_csv_regex='^modelo_importacao_processos\.csv$'

for file in $staged_files; do
  if echo "$file" | grep -Eiq "$blocked_path_regex"; then
    echo "Commit bloqueado: caminho sensível detectado: $file" >&2
    exit 1
  fi

  if echo "$file" | grep -Eiq "$blocked_ext_regex"; then
    echo "Commit bloqueado: extensão de dado sensível detectada: $file" >&2
    exit 1
  fi

  if echo "$file" | grep -Eiq '\.csv$'; then
    if ! echo "$file" | grep -Eq "$allowed_csv_regex"; then
      echo "Commit bloqueado: CSV não permitido: $file" >&2
      echo "CSV permitido neste repositório: modelo_importacao_processos.csv" >&2
      exit 1
    fi
  fi
done

if git diff --cached -U0 -- . ':(exclude).githooks/**' | grep -E '^\+.*(^|[^0-9A-Za-z])[0-9]{3}\.?[0-9]{3}\.?[0-9]{3}-?[0-9]{2}([^0-9A-Za-z]|$)' >/dev/null; then
  echo "Commit bloqueado: padrão tipo CPF detectado no diff staged." >&2
  exit 1
fi

exit 0
